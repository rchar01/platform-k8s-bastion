#!/usr/bin/env bash
set -euo pipefail

PY_MODULE="/usr/local/lib/bastion/python/bastion_bootstrapd_client.py"

if [[ -f "$PY_MODULE" ]]; then
  exec python3 "$PY_MODULE" "$@"
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_MODULE="${SCRIPT_DIR}/../lib/python/bastion_bootstrapd_client.py"

exec python3 "$REPO_MODULE" "$@"
