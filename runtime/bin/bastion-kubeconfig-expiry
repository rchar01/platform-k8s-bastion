#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-kubeconfig-expiry"

# --------------------------------------------------
# Resolve bastion library location
# --------------------------------------------------

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"

# --------------------------------------------------
# Defaults
# --------------------------------------------------

WARN_DAYS="${WARN_DAYS:-30}"
DEFAULT_CONFIG="${HOME}/.kube/config"

usage() {
  cat << EOF
Usage:
  kubeconfig-expiry [FILE|DIR]

Default:
  scans \$HOME/.kube/config

If DIR is provided:
  scans DIR/config and DIR/*.kubeconfig

Env:
  WARN_DAYS=30   warn when cert expires within N days
EOF
}

# --------------------------------------------------
# Requirements
# --------------------------------------------------

need_cmd kubectl
need_cmd jq
need_cmd openssl
need_cmd base64
need_cmd date

# --------------------------------------------------
# Helpers
# --------------------------------------------------

days_left() {
  local notafter="$1"
  local exp now

  exp="$(date -d "$notafter" +%s 2> /dev/null || true)"
  now="$(date +%s)"

  [[ -n "$exp" ]] || {
    echo "?"
    return
  }
  echo $(((exp - now) / 86400))
}

print_cert_info() {
  local label="$1"
  local pem="$2"

  local endline notafter dl

  endline="$(openssl x509 -in "$pem" -noout -enddate 2> /dev/null || true)"
  notafter="${endline#notAfter=}"
  dl="$(days_left "$notafter")"

  if [[ "$dl" != "?" && "$dl" -le "$WARN_DAYS" ]]; then
    log_warn "$(printf '%-45s %4s days  %s' "$label" "$dl" "$notafter")"
  else
    log_info "$(printf '%-45s %4s days  %s' "$label" "$dl" "$notafter")"
  fi
}

collect_files() {
  local target="$1"
  files=()

  if [[ -f "$target" ]]; then
    files=("$target")
    return
  fi

  if [[ -d "$target" ]]; then
    shopt -s nullglob

    # Primary default
    [[ -f "$target/config" ]] && files+=("$target/config")

    # Additional kubeconfigs
    for f in "$target"/*.kubeconfig; do
      files+=("$f")
    done

    ((${#files[@]} > 0)) || die "No kubeconfig files found in $target"
    return
  fi

  die "Not found: $target"
}

process_kubeconfig() {
  local kc="$1"

  log_debug "Processing: $kc"

  local cfg_json
  cfg_json="$(kubectl config view --raw --kubeconfig "$kc" -o json 2> /dev/null || true)"

  [[ -n "$cfg_json" ]] || {
    log_warn "Cannot read kubeconfig: $kc"
    return
  }

  mapfile -t entries < <(
    jq -r '
      .users[]? |
      .name as $n |
      (.user["client-certificate-data"] // "") as $ccd |
      (.user["client-certificate"] // "") as $cc |
      [$n,$ccd,$cc] | @tsv
    ' <<< "$cfg_json"
  )

  ((${#entries[@]})) || {
    log_debug "$(basename "$kc") (no users entries)"
    return
  }

  for line in "${entries[@]}"; do
    IFS=$'\t' read -r uname ccd ccfile <<< "$line"
    local label
    label="$(basename "$kc")::$uname"

    if [[ -n "$ccd" ]]; then
      tmp="$(mktemp)"

      if ! printf '%s' "$ccd" | base64 -d > "$tmp" 2> /dev/null; then
        log_warn "Decode failed: $label"
        rm -f "$tmp"
        continue
      fi

      print_cert_info "$label" "$tmp"
      rm -f "$tmp"

    elif [[ -n "$ccfile" ]]; then
      if [[ "$ccfile" != /* ]]; then
        ccfile="$(cd "$(dirname "$kc")" && readlink -f "$ccfile" 2> /dev/null || true)"
      fi

      [[ -f "$ccfile" ]] || {
        log_warn "Missing cert file for $label: $ccfile"
        continue
      }

      print_cert_info "$label" "$ccfile"

    else
      log_debug "$label (no client certificate)"
    fi
  done
}

# --------------------------------------------------
# Main
# --------------------------------------------------

main() {
  local target="${1:-$DEFAULT_CONFIG}"

  log_debug "Scanning target: $target"
  log_debug "WARN_DAYS=$WARN_DAYS"

  collect_files "$target"

  for kc in "${files[@]}"; do
    process_kubeconfig "$kc"
  done
}

main "$@"
