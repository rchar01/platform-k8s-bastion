#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-bootstrap-admin-kubeconfig"

# --------------------------------------------------
# Resolve bastion library location
# --------------------------------------------------

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/policy.sh"

KUBECONFIG_WRITER="${LIB_DIR}/python/bastion_kubeconfig_writer.py"

# --------------------------------------------------
# Defaults
# --------------------------------------------------

POLICY="/etc/bastion/access-policy.yaml"
ADMIN_KUBECONFIG=""
ADMIN_GROUP="k8s-admin"

usage() {
  cat << EOF
Usage:
  bastion-bootstrap-admin-kubeconfig [--policy FILE] [--admin-kubeconfig FILE] [--admin-group GROUP]

Bootstraps users as Kubernetes admins if they belong to group 'k8s-admin'
in the policy file.

Defaults:
  --policy            $POLICY
  --admin-kubeconfig  required
  --admin-group       $ADMIN_GROUP
EOF
}

# --------------------------------------------------
# Args
# --------------------------------------------------

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --policy)
        require_arg "$1" "${2-}"
        POLICY="$2"
        shift 2
        ;;
      --admin-kubeconfig)
        require_arg "$1" "${2-}"
        ADMIN_KUBECONFIG="$2"
        shift 2
        ;;
      --admin-group)
        require_arg "$1" "${2-}"
        ADMIN_GROUP="$2"
        shift 2
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done
}

validate_inputs() {
  [[ -f "$POLICY" ]] || die "Policy not found: $POLICY"
  [[ -n "$ADMIN_KUBECONFIG" ]] || die "--admin-kubeconfig is required"
  [[ -f "$ADMIN_KUBECONFIG" ]] || die "Admin kubeconfig not found: $ADMIN_KUBECONFIG"
  policy_validate_linux_name "admin group" "$ADMIN_GROUP"
  POLICY_FILE="$POLICY"
  policy_read
}

copy_if_changed() {
  local src="$1"
  local user="$2"
  local home_dir="$3"
  local result changed=0 unchanged=0

  [[ -f "$KUBECONFIG_WRITER" ]] || die "Kubeconfig writer not found: $KUBECONFIG_WRITER"
  if ! result="$(python3 "$KUBECONFIG_WRITER" --user "$user" --home-dir "$home_dir" --dest config --source "$src" --remove bootstrap 2>&1)"; then
    die "Failed to install admin kubeconfig for $user: $result"
  fi
  if [[ $'\n'"$result"$'\n' == *$'\nremoved bootstrap\n'* ]]; then
    log_info "Removed bootstrap config for $user"
  fi
  [[ $'\n'"$result"$'\n' == *$'\nchanged config\n'* ]] && changed=1
  [[ $'\n'"$result"$'\n' == *$'\nunchanged config\n'* ]] && unchanged=1
  if ((changed + unchanged != 1)); then
    die "Unexpected admin kubeconfig writer result for $user: $result"
  fi
  ((changed == 1))
}

user_is_admin_in_policy() {
  local user="$1"

  USER_KEY="$user" ADMIN_GROUP_KEY="$ADMIN_GROUP" yq -e '.users[strenv(USER_KEY)].ensureGroups // [] | index(strenv(ADMIN_GROUP_KEY))' "$POLICY" > /dev/null 2>&1
}

bootstrap_admin_user() {
  local user="$1"

  # Must exist on host
  if ! getent passwd "$user" > /dev/null 2>&1; then
    log_warn "User not found on host: $user (skipping)"
    return
  fi

  if ! user_is_admin_in_policy "$user"; then
    log_debug "User $user is not in $ADMIN_GROUP group (skipping)"
    return
  fi

  local home_dir

  home_dir="$(getent passwd "$user" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || {
    log_warn "Cannot resolve home for $user (skipping)"
    return
  }

  if copy_if_changed "$ADMIN_KUBECONFIG" "$user" "$home_dir"; then
    log_info "Installed admin kubeconfig for $user"
  else
    log_info "Admin kubeconfig unchanged for $user - skipping copy"
  fi
}

bootstrap_admins() {
  log_info "Processing admin users from policy"

  mapfile -t users < <(yq -r '(.users // {}) | keys[]' "$POLICY")

  for u in "${users[@]}"; do
    bootstrap_admin_user "$u"
  done
}

# --------------------------------------------------
# Main
# --------------------------------------------------

main() {
  require_root

  need_cmd yq
  need_cmd getent
  need_cmd python3

  parse_args "$@"
  validate_inputs

  log_info "Using policy: $POLICY"
  log_info "Using admin kubeconfig: $ADMIN_KUBECONFIG"
  log_info "Using admin group: $ADMIN_GROUP"

  bootstrap_admins

  log_info "Admin bootstrap complete."
}

main "$@"
