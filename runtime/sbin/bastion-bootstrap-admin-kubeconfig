#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-bootstrap-admin-kubeconfig"

# --------------------------------------------------
# Resolve bastion library location
# --------------------------------------------------

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"

# --------------------------------------------------
# Defaults
# --------------------------------------------------

POLICY="/etc/bastion/access-policy.yaml"
ADMIN_KUBECONFIG=""

usage() {
  cat << EOF
Usage:
  bastion-bootstrap-admin-kubeconfig [--policy FILE] [--admin-kubeconfig FILE]

Bootstraps users as Kubernetes admins if they belong to group 'k8s-admin'
in the policy file.

Defaults:
  --policy            $POLICY
  --admin-kubeconfig  required
EOF
}

# --------------------------------------------------
# Args
# --------------------------------------------------

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --policy)
        require_arg "$1" "${2-}"
        POLICY="$2"
        shift 2
        ;;
      --admin-kubeconfig)
        require_arg "$1" "${2-}"
        ADMIN_KUBECONFIG="$2"
        shift 2
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done
}

validate_inputs() {
  [[ -f "$POLICY" ]] || die "Policy not found: $POLICY"
  [[ -n "$ADMIN_KUBECONFIG" ]] || die "--admin-kubeconfig is required"
  [[ -f "$ADMIN_KUBECONFIG" ]] || die "Admin kubeconfig not found: $ADMIN_KUBECONFIG"
}

sha256() {
  sha256sum "$1" | awk '{print $1}'
}

prepare_user_kube_dir() {
  local user="$1"
  local home_dir="$2"
  local primary_group="$3"
  local kube_dir="$4"
  local user_uid home_owner kube_owner

  [[ "$home_dir" == /home/* ]] || die "Unsafe home directory for user $user: $home_dir"
  [[ -d "$home_dir" ]] || die "Home directory not found for user $user: $home_dir"
  [[ ! -L "$home_dir" ]] || die "Refusing symlinked home directory for user $user: $home_dir"

  user_uid="$(id -u "$user")"
  home_owner="$(stat -c '%u' "$home_dir")"
  [[ "$home_owner" == "$user_uid" ]] || die "Home directory owner mismatch for user $user: $home_dir"

  [[ ! -L "$kube_dir" ]] || die "Refusing symlinked kube directory for user $user: $kube_dir"
  [[ ! -e "$kube_dir" || -d "$kube_dir" ]] || die "Refusing non-directory kube path for user $user: $kube_dir"

  if [[ ! -d "$kube_dir" ]]; then
    install -d -m 0700 -o "$user" -g "$primary_group" "$kube_dir"
  fi

  [[ ! -L "$kube_dir" && -d "$kube_dir" ]] || die "Unsafe kube directory for user $user: $kube_dir"
  chown -h "$user:$primary_group" "$kube_dir"
  [[ ! -L "$kube_dir" ]] || die "Refusing symlinked kube directory for user $user: $kube_dir"
  chmod 0700 "$kube_dir"

  kube_owner="$(stat -c '%u' "$kube_dir")"
  [[ "$kube_owner" == "$user_uid" ]] || die "Kube directory owner mismatch for user $user: $kube_dir"
}

copy_if_changed() {
  local src="$1"
  local dst="$2"
  local user="$3"
  local primary_group="$4"

  [[ ! -L "$dst" ]] || die "Refusing symlinked kubeconfig path for user $user: $dst"
  [[ ! -e "$dst" || -f "$dst" ]] || die "Refusing non-file kubeconfig path for user $user: $dst"

  if [[ -f "$dst" ]]; then
    local s d
    s="$(sha256 "$src")"
    d="$(sha256 "$dst")"
    if [[ "$s" == "$d" ]]; then
      return 1
    fi
  fi

  local dst_dir tmp
  dst_dir="$(dirname "$dst")"
  tmp="$(mktemp "${dst_dir}/.config.XXXXXX")"
  install -m 0600 "$src" "$tmp"
  chown "$user:$primary_group" "$tmp"

  [[ ! -L "$dst" ]] || {
    rm -f "$tmp"
    die "Refusing symlinked kubeconfig path for user $user: $dst"
  }
  [[ ! -e "$dst" || -f "$dst" ]] || {
    rm -f "$tmp"
    die "Refusing non-file kubeconfig path for user $user: $dst"
  }

  mv -T "$tmp" "$dst"
  [[ ! -L "$dst" && -f "$dst" ]] || die "Unsafe kubeconfig path after install for user $user: $dst"
  chown "$user:$primary_group" "$dst"
  chmod 0600 "$dst"
  return 0
}

user_is_admin_in_policy() {
  local user="$1"

  USER_KEY="$user" yq -e '.users[strenv(USER_KEY)].ensureGroups // [] | index("k8s-admin")' "$POLICY" > /dev/null 2>&1
}

bootstrap_admin_user() {
  local user="$1"

  # Must exist on host
  if ! getent passwd "$user" > /dev/null 2>&1; then
    log_warn "User not found on host: $user (skipping)"
    return
  fi

  if ! user_is_admin_in_policy "$user"; then
    log_debug "User $user is not in k8s-admin group (skipping)"
    return
  fi

  local home_dir primary_group kube_dir config bootstrap

  home_dir="$(getent passwd "$user" | cut -d: -f6)"
  [[ -n "$home_dir" ]] || {
    log_warn "Cannot resolve home for $user (skipping)"
    return
  }

  primary_group="$(id -gn "$user" 2> /dev/null || true)"
  [[ -n "$primary_group" ]] || {
    log_warn "Cannot resolve primary group for $user (skipping)"
    return
  }

  kube_dir="$home_dir/.kube"
  config="$kube_dir/config"
  bootstrap="$kube_dir/bootstrap"

  prepare_user_kube_dir "$user" "$home_dir" "$primary_group" "$kube_dir"

  # Remove bootstrap config if exists
  if [[ -f "$bootstrap" ]]; then
    rm -f "$bootstrap"
    log_info "Removed bootstrap config for $user"
  fi

  if copy_if_changed "$ADMIN_KUBECONFIG" "$config" "$user" "$primary_group"; then
    log_info "Installed admin kubeconfig for $user"
  else
    [[ ! -L "$config" ]] || die "Refusing symlinked kubeconfig path for user $user: $config"
    chown "$user:$primary_group" "$config" || true
    chmod 0600 "$config" || true
    log_info "Admin kubeconfig unchanged for $user — skipping copy"
  fi
}

bootstrap_admins() {
  log_info "Processing admin users from policy"

  mapfile -t users < <(yq -r '.users | keys[]' "$POLICY")

  for u in "${users[@]}"; do
    bootstrap_admin_user "$u"
  done
}

# --------------------------------------------------
# Main
# --------------------------------------------------

main() {
  require_root

  need_cmd yq
  need_cmd getent
  need_cmd id
  need_cmd install
  need_cmd sha256sum
  need_cmd rm
  need_cmd chmod
  need_cmd chown
  need_cmd dirname
  need_cmd mktemp
  need_cmd mv
  need_cmd stat

  parse_args "$@"
  validate_inputs

  log_info "Using policy: $POLICY"
  log_info "Using admin kubeconfig: $ADMIN_KUBECONFIG"

  bootstrap_admins

  log_info "Admin bootstrap complete."
}

main "$@"
