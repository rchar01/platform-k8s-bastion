#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-bootstrap-kubeconfig"

# --------------------------------------------------
# Resolve bastion library location
# --------------------------------------------------

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/contract.sh"
source "${LIB_DIR}/policy.sh"
source "${LIB_DIR}/audit.sh"

KUBECONFIG_WRITER="${LIB_DIR}/python/bastion_kubeconfig_writer.py"

# --------------------------------------------------
# Defaults
# --------------------------------------------------

POLICY="${POLICY_FILE}"
ADMIN_KUBECONFIG="${ADMIN_KUBECONFIG_FILE}"
BOOTSTRAP_TOKEN_TTL_SECONDS=""
OFFLINE_BOOTSTRAP=0

TARGET_USER=""
BOOTSTRAP_ALL=0

usage() {
  cat << EOF
Usage:
  bastion-bootstrap-kubeconfig --user USER
  bastion-bootstrap-kubeconfig --all

Options:
  --policy FILE   policy yaml (default: $POLICY)
  --token-ttl-sec N   bootstrap token TTL in seconds (default/max loaded from policy)
  --offline-bootstrap  write synthetic bootstrap kubeconfig without issuer/API calls
EOF
}

# --------------------------------------------------
# Args
# --------------------------------------------------

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user)
        require_arg "$1" "${2-}"
        TARGET_USER="$2"
        shift 2
        ;;
      --all)
        BOOTSTRAP_ALL=1
        shift
        ;;
      --policy)
        require_arg "$1" "${2-}"
        POLICY="$2"
        shift 2
        ;;
      --token-ttl-sec)
        require_arg "$1" "${2-}"
        BOOTSTRAP_TOKEN_TTL_SECONDS="$2"
        shift 2
        ;;
      --offline-bootstrap)
        OFFLINE_BOOTSTRAP=1
        shift
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  if [[ -z "$TARGET_USER" && "$BOOTSTRAP_ALL" -eq 0 ]]; then
    die "Specify --user or --all"
  fi

  if [[ -n "$BOOTSTRAP_TOKEN_TTL_SECONDS" ]]; then
    [[ "$BOOTSTRAP_TOKEN_TTL_SECONDS" =~ ^[0-9]+$ ]] || die "--token-ttl-sec must be integer"
    if ((BOOTSTRAP_TOKEN_TTL_SECONDS < 60)); then
      die "--token-ttl-sec too small (min 60)"
    fi
  fi
}

# --------------------------------------------------
# Validation
# --------------------------------------------------

validate_policy() {
  [[ -f "$POLICY" ]] || die "Policy not found: $POLICY"
}

policy_has_user() {
  local user="$1"
  USER_KEY="$user" yq -e '.users[strenv(USER_KEY)]' "$POLICY" > /dev/null 2>&1
}

install_user_kubeconfig() {
  local content="$1"
  local user="$2"
  local home_dir="$3"
  local result

  [[ -f "$KUBECONFIG_WRITER" ]] || die "Kubeconfig writer not found: $KUBECONFIG_WRITER"
  if ! result="$(printf '%s\n' "$content" | python3 "$KUBECONFIG_WRITER" --user "$user" --home-dir "$home_dir" --dest bootstrap --stdin 2>&1)"; then
    die "Failed to install bootstrap kubeconfig for $user: $result"
  fi
  if [[ $'\n'"$result"$'\n' != *$'\nchanged bootstrap\n'* && $'\n'"$result"$'\n' != *$'\nunchanged bootstrap\n'* ]]; then
    die "Unexpected bootstrap kubeconfig writer result for $user: $result"
  fi
}

# --------------------------------------------------
# Core bootstrap logic
# --------------------------------------------------

bootstrap_user() {
  local user="$1"

  log_info "Bootstrapping kubeconfig for $user"

  policy_has_user "$user" || die "User '$user' not defined in policy"

  local home_dir
  home_dir="$(getent passwd "$user" | cut -d: -f6)"

  [[ -n "$home_dir" ]] || die "User not found on system: $user"

  local token_json token_id token_expires bootstrap_kubeconfig
  local cluster server ca

  if [[ "$OFFLINE_BOOTSTRAP" -eq 1 ]]; then
    cluster="$BASTION_CLUSTER_NAME"
    server="$BASTION_CLUSTER_SERVER"
    ca="$BASTION_CLUSTER_CA_FILE"
    bootstrap_kubeconfig="$(
      cat << EOF
apiVersion: v1
kind: Config
clusters:
- name: ${cluster}
  cluster:
    server: ${server}
    certificate-authority: ${ca}
contexts:
- name: bootstrap
  context:
    cluster: ${cluster}
    user: ${user}-bootstrap
current-context: bootstrap
users:
- name: ${user}-bootstrap
  user:
    token: offline-bootstrap-${user}
EOF
    )"
    audit_event "bootstrap_token_issue" "ok" "user=$user source=offline ttl=${BOOTSTRAP_TOKEN_TTL_SECONDS}"
  else
    audit_event "bootstrap_token_issue" "start" "user=$user ttl=${BOOTSTRAP_TOKEN_TTL_SECONDS}"
    token_json="$(bastion-bootstrap-token-issue --user "$user" --reason initial-enrollment --ttl-seconds "$BOOTSTRAP_TOKEN_TTL_SECONDS" --json --admin-kubeconfig "$ADMIN_KUBECONFIG")"
    token_id="$(jq -r '.tokenId // empty' <<< "$token_json")"
    token_expires="$(jq -r '.expiresAt // empty' <<< "$token_json")"
    bootstrap_kubeconfig="$(jq -r '.bootstrapKubeconfig // empty' <<< "$token_json")"
    [[ -n "$bootstrap_kubeconfig" ]] || die "Token issuer returned empty bootstrapKubeconfig for user: $user"
    audit_event "bootstrap_token_issue" "ok" "user=$user token_id_redacted=true expires_at=${token_expires:-unknown}"
  fi

  install_user_kubeconfig "$bootstrap_kubeconfig" "$user" "$home_dir"

  log_info "Bootstrap kubeconfig installed for $user"
}

bootstrap_all_users() {
  log_info "Bootstrapping all users from policy"

  mapfile -t users < <(yq -r '(.users // {}) | keys[]' "$POLICY")

  for u in "${users[@]}"; do
    if ! getent passwd "$u" > /dev/null 2>&1; then
      log_warn "User not found on system: $u (skipping)"
      continue
    fi
    bootstrap_user "$u"
  done
}

# --------------------------------------------------
# Main
# --------------------------------------------------

main() {
  require_root

  parse_args "$@"

  need_cmd yq
  need_cmd getent
  need_cmd jq
  need_cmd python3
  if [[ "$OFFLINE_BOOTSTRAP" -eq 0 ]]; then
    need_cmd bastion-bootstrap-token-issue
  fi

  POLICY_FILE="$POLICY"
  policy_read

  if [[ -z "$BOOTSTRAP_TOKEN_TTL_SECONDS" ]]; then
    BOOTSTRAP_TOKEN_TTL_SECONDS="$BOOTSTRAP_TOKEN_TTL_DEFAULT_SECONDS"
  fi
  if ((BOOTSTRAP_TOKEN_TTL_SECONDS > BOOTSTRAP_TOKEN_TTL_MAX_SECONDS)); then
    die "--token-ttl-sec exceeds max ${BOOTSTRAP_TOKEN_TTL_MAX_SECONDS}"
  fi
  validate_policy

  if [[ "$OFFLINE_BOOTSTRAP" -eq 1 ]]; then
    log_warn "Offline bootstrap mode enabled: synthetic kubeconfigs will be generated"
  fi

  if [[ "$BOOTSTRAP_ALL" -eq 1 ]]; then
    bootstrap_all_users
  else
    bootstrap_user "$TARGET_USER"
  fi

  log_info "Done."
}

main "$@"
